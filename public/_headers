/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; img-src 'self' data: https://maps.googleapis.com https://maps.gstatic.com; script-src 'self' https://static.cloudflareinsights.com https://maps.googleapis.com 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; frame-src https://www.google.com; connect-src 'self' https://maps.googleapis.com https://*.googleapis.com

/admin/*
  X-Robots-Tag: noindex, nofollow
