---
export const prerender = true;
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const locali = await getCollection("locali");
  return locali.map((loc) => ({
    params: { slug: loc.data.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;
const { Content } = await render(loc);
const visiteOrdinate = [...loc.data.visite].sort((a, b) => b.data.localeCompare(a.data));
---

<Layout title={`${loc.data.nome} — Aperitivi Urbani`} description={`Recensione di ${loc.data.nome} a ${loc.data.zona ?? "Milano"}`}>
  <p><a href="/" style="color:var(--accent-soft)">← tutti i locali</a></p>

  <article class="card scheda">
    <h2 style="margin:0 0 0.25rem">{loc.data.nome}</h2>
    <p class="muted" style="margin-top:0">
      {loc.data.zona ?? "Milano"}
      {loc.data.indirizzo && <> · {loc.data.indirizzo}</>}
      {" · "}{loc.data.tipo.join(", ")}
      {loc.data.fascia_prezzo && <> · {loc.data.fascia_prezzo}</>}
    </p>

    {loc.data.voto_dedotto != null && (
      <p class="stars" style="font-size:1.3rem;margin:0.5rem 0">
        {"★".repeat(Math.round(loc.data.voto_dedotto))}{"☆".repeat(5 - Math.round(loc.data.voto_dedotto))}
        {loc.data.sentiment && <span class="muted" style="font-weight:400;font-size:0.9rem;margin-left:0.5rem">— tono: {loc.data.sentiment}</span>}
      </p>
    )}

    {loc.data.sponsorizzato && (
      <p style="background:var(--warn-bg);border-left:3px solid var(--accent);padding:0.6rem 1rem;font-size:0.9rem;border-radius:4px">
        Contenuto sponsorizzato / in collaborazione (come dichiarato nel post originale)
      </p>
    )}

    {loc.data.foto && loc.data.foto.length > 0 && (
      <div class="gallery" style="margin:1rem 0">
        <div style="position:relative">
          <img
            id="gallery-hero-img"
            src={`/images/locali/${loc.data.slug}/${loc.data.foto[0]}`}
            alt={loc.data.nome}
            style="width:100%;aspect-ratio:4/3;object-fit:cover;border-radius:10px;display:block"
          />
          {loc.data.foto.length > 1 && (
            <div id="gallery-counter" style="position:absolute;bottom:8px;right:8px;background:rgba(27,57,66,0.55);color:#fff;font-size:0.75rem;padding:0.15rem 0.6rem;border-radius:999px">
              1 / {loc.data.foto.length}
            </div>
          )}
        </div>
        {loc.data.foto.length > 1 && (
          <div style="display:flex;gap:0.4rem;margin-top:0.5rem;overflow-x:auto">
            {loc.data.foto.map((f, i) => (
              <img
                class="gallery-thumb"
                data-index={i}
                data-full={`/images/locali/${loc.data.slug}/${f}`}
                src={`/images/locali/${loc.data.slug}/${f}`}
                alt=""
                style={`width:56px;height:56px;object-fit:cover;border-radius:6px;cursor:pointer;flex:0 0 auto;border:2px solid ${i === 0 ? "var(--accent)" : "transparent"}`}
              />
            ))}
          </div>
        )}
      </div>
    )}

    {loc.data.foto && loc.data.foto.length > 1 && (
      <script is:inline define:vars={{ totale: loc.data.foto.length }}>
        (function() {
          var hero = document.getElementById('gallery-hero-img');
          var counter = document.getElementById('gallery-counter');
          var thumbs = document.querySelectorAll('.gallery-thumb');
          thumbs.forEach(function(t) {
            t.addEventListener('click', function() {
              hero.src = t.getAttribute('data-full');
              thumbs.forEach(function(other) {
                other.style.border = '2px solid transparent';
              });
              t.style.border = '2px solid var(--accent)';
              if (counter) {
                counter.textContent = (parseInt(t.getAttribute('data-index'), 10) + 1) + ' / ' + totale;
              }
            });
          });
        })();
      </script>
    )}

    {loc.data.piatti_drink_citati.length > 0 && (
      <section>
        <h3>Citati nei post</h3>
        <ul>
          {loc.data.piatti_drink_citati.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    <section>
      <h3>Visite</h3>
      {visiteOrdinate.map((v) => (
        <article style="border-top:1px solid var(--cream-border);padding:1rem 0">
          <p class="muted" style="font-size:0.9rem;margin:0 0 0.5rem">
            {v.data}
            {v.fonte_tipo === "lista" && <span style="margin-left:0.5rem;background:var(--accent-soft);color:var(--ink);font-size:0.7rem;padding:0.1rem 0.45rem;border-radius:4px">da post-lista</span>}
            {" · "}<a href={v.post_url} rel="noopener" style="color:var(--accent)">post originale ↗</a>
          </p>
          {v.foto.length > 0 && (
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.75rem">
              {v.foto.map((f) => <img src={f} alt="" style="max-width:240px;border-radius:6px" />)}
            </div>
          )}
          <p style="white-space:pre-line">{v.caption}</p>
        </article>
      ))}
    </section>

    {loc.data.indirizzo && (
      <section style="margin-top:2rem">
        <h3>Dove si trova</h3>
        <p class="muted" style="font-size:0.95rem;margin-bottom:0.75rem">
          {loc.data.indirizzo}{loc.data.citta ? `, ${loc.data.citta}` : ""}
        </p>
        <div style="border-radius:10px;overflow:hidden;border:1px solid var(--cream-border)">
          <iframe
            width="100%"
            height="380"
            style="border:0;display:block"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src={`https://www.google.com/maps/embed/v1/place?key=${import.meta.env.GOOGLE_MAPS_API_KEY}&q=${encodeURIComponent((loc.data.indirizzo ?? "") + ", " + (loc.data.citta ?? "Milano"))}`}
          ></iframe>
        </div>
      </section>
    )}

    <section style="margin-top:2rem">
      <Content />
    </section>
  </article>
</Layout>

<style>
  .scheda { padding: 1.75rem; }
  .scheda h3 { margin-top: 1.5rem; }
  @media (max-width: 640px) {
    .scheda { padding: 1.25rem; }
  }
</style>
